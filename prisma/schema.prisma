generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  salesforceId  String?  @unique
  email         String   @unique
  name          String
  role          UserRole @default(REP)
  accessToken   String?
  refreshToken  String?
  instanceUrl   String?
  onboardingComplete Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  deals           Deal[]
  sessions        Session[]
  analyticsEvents AnalyticsEvent[]
}

enum UserRole {
  REP
  MANAGER
  REVOPS
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Deal {
  id               String    @id @default(cuid())
  salesforceId     String?
  name             String
  amount           Float
  stage            String
  closeDate        DateTime
  ownerName        String
  ownerId          String?
  lastActivityDate DateTime?
  stageEnteredAt   DateTime?
  userId           String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities    Activity[]
  stakeholders  Stakeholder[]
  riskScores    RiskScore[]

  @@unique([salesforceId, userId])
  @@index([userId])
  @@index([closeDate])
}

model Activity {
  id        String       @id @default(cuid())
  dealId    String
  type      ActivityType
  subject   String?
  date      DateTime
  createdAt DateTime     @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

enum ActivityType {
  EMAIL
  MEETING
  CALL
  TASK
  OTHER
}

model Stakeholder {
  id                  String    @id @default(cuid())
  dealId              String
  name                String
  email               String?
  lastEngagementDate  DateTime?
  engagementCount     Int       @default(0)
  createdAt           DateTime  @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

model RiskScore {
  id              String          @id @default(cuid())
  dealId          String
  score           Int?
  status          ScoreStatus     @default(SCORED)
  explanation     String?
  recommendations Json?
  factors         Json?
  createdAt       DateTime        @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([createdAt])
}

enum ScoreStatus {
  SCORED
  NOT_ENOUGH_DATA
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  eventType String
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([createdAt])
}
