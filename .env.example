# Database (Neon Postgres)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Salesforce OAuth
SALESFORCE_CLIENT_ID=""
SALESFORCE_CLIENT_SECRET=""
SALESFORCE_CALLBACK_URL="http://localhost:3000/api/auth/salesforce/callback"
SALESFORCE_LOGIN_URL="https://login.salesforce.com"

# Claude API (Anthropic)
ANTHROPIC_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Set to true only when Salesforce credentials are not configured.
# When real SALESFORCE_CLIENT_ID / SECRET are present, OAuth is used instead.
DEMO_MODE="false"
